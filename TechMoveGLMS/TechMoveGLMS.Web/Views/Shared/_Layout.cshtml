<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechMove GLMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TechMoveGLMS.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="tm-page">
        <header class="tm-intro">
            <span class="tm-pill">Logistics management</span>
            <div class="tm-intro-grid">
                <div>
                    <div class="tm-brand-lockup" aria-label="Move-Tech logo">
                        <span>MT</span>
                    </div>
                    <h1>@(ViewData["Title"] ?? "Dashboard")</h1>
                </div>
                <p class="tm-intro-copy">
                    A monolithic enterprise prototype for clients, contracts, signed agreements, service requests, and USD to ZAR logistics costing.
                </p>
            </div>
        </header>

        <section class="tm-app-shell">
            <aside class="tm-side-rail" aria-label="Primary navigation">
                <a class="tm-logo" asp-controller="Home" asp-action="Index" aria-label="Dashboard">
                    MT
                </a>
                <nav class="tm-rail-nav">
                    <a asp-controller="Home" asp-action="Index" title="Dashboard">D</a>
                    <a asp-controller="Clients" asp-action="Index" title="Clients">C</a>
                    <a asp-controller="Contracts" asp-action="Index" title="Contracts">K</a>
                    <a asp-controller="ServiceRequests" asp-action="Index" title="Service Requests">S</a>
                    <a asp-controller="Contracts" asp-action="Search" title="Contract Search">F</a>
                </nav>
            </aside>

            <div class="tm-workspace">
                <nav class="navbar navbar-expand-lg tm-topbar">
                    <div class="container-fluid px-0">
                        <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Overview</a>
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#tmNavigation" aria-controls="tmNavigation"
                                aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div id="tmNavigation" class="navbar-collapse collapse">
                            <ul class="navbar-nav me-auto">
                                <li class="nav-item"><a class="nav-link" asp-controller="Clients" asp-action="Index">Clients</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Contracts" asp-action="Index">Contracts</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ServiceRequests" asp-action="Index">Requests</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Contracts" asp-action="Search">Search</a></li>
                            </ul>
                            <div class="tm-search">Search GLMS</div>
                        </div>
                    </div>
                </nav>

                <main role="main" class="tm-content">
                    @if (TempData["StatusMessage"] is string statusMessage)
                    {
                        <div class="alert alert-warning mb-3">@statusMessage</div>
                    }
                    @RenderBody()
                </main>
            </div>
        </section>

        <footer class="tm-footer">
            &copy; 2026 TechMove Global Logistics Management System
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
