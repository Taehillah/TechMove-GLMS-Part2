@model Contract
@{
    ViewData["Title"] = "Contract Details";
}

<h1 class="h3 mb-3">Contract Details</h1>
<dl class="row">
    <dt class="col-sm-3">Client</dt>
    <dd class="col-sm-9">@Model.Client?.Name</dd>
    <dt class="col-sm-3">Service Level</dt>
    <dd class="col-sm-9">@Model.ServiceLevel</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Start Date</dt>
    <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>
    <dt class="col-sm-3">End Date</dt>
    <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>
    <dt class="col-sm-3">Signed Agreement</dt>
    <dd class="col-sm-9">
        @if (!string.IsNullOrWhiteSpace(Model.SignedAgreementPath))
        {
            <a class="btn btn-sm btn-outline-primary" href="@Model.SignedAgreementPath" download>Download PDF</a>
        }
        else
        {
            <span>Not uploaded</span>
        }
    </dd>
</dl>

<h2 class="h5 mt-4">Service Requests</h2>
<div class="table-responsive">
    <table class="table table-sm">
        <thead><tr><th>Description</th><th>Status</th><th>USD</th><th>ZAR</th></tr></thead>
        <tbody>
        @foreach (var request in Model.ServiceRequests)
        {
            <tr>
                <td>@request.Description</td>
                <td>@request.Status</td>
                <td>@request.CostUsd.ToString("C")</td>
                <td>R @request.CostZar.ToString("N2")</td>
            </tr>
        }
        </tbody>
    </table>
</div>

<a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
<a class="btn btn-outline-secondary" asp-action="Index">Back</a>
