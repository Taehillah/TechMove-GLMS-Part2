@model Contract
@{
    ViewData["Title"] = "Delete Contract";
}

<h1 class="h3 mb-3">Delete Contract</h1>
<div class="alert alert-warning">Confirm deletion of contract <strong>@Model.ServiceLevel</strong> for @Model.Client?.Name.</div>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
</form>
