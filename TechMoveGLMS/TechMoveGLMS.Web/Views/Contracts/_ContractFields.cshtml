@model ContractFormViewModel

<div class="col-md-6">
    <label asp-for="ClientId" class="form-label"></label>
    <select asp-for="ClientId" class="form-select" asp-items="ViewBag.ClientId">
        <option value="">Select client</option>
    </select>
    <span asp-validation-for="ClientId" class="text-danger"></span>
</div>
<div class="col-md-6">
    <label asp-for="ServiceLevel" class="form-label"></label>
    <input asp-for="ServiceLevel" class="form-control" />
    <span asp-validation-for="ServiceLevel" class="text-danger"></span>
</div>
<div class="col-md-4">
    <label asp-for="StartDate" class="form-label"></label>
    <input asp-for="StartDate" class="form-control" />
    <span asp-validation-for="StartDate" class="text-danger"></span>
</div>
<div class="col-md-4">
    <label asp-for="EndDate" class="form-label"></label>
    <input asp-for="EndDate" class="form-control" />
    <span asp-validation-for="EndDate" class="text-danger"></span>
</div>
<div class="col-md-4">
    <label asp-for="Status" class="form-label"></label>
    <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<ContractStatus>()"></select>
    <span asp-validation-for="Status" class="text-danger"></span>
</div>
<div class="col-12">
    <label asp-for="SignedAgreement" class="form-label"></label>
    <input asp-for="SignedAgreement" class="form-control" accept="application/pdf,.pdf" />
    <span asp-validation-for="SignedAgreement" class="text-danger"></span>
    @if (!string.IsNullOrWhiteSpace(Model.ExistingSignedAgreementFileName))
    {
        <div class="form-text">Current file: @Model.ExistingSignedAgreementFileName</div>
    }
</div>
