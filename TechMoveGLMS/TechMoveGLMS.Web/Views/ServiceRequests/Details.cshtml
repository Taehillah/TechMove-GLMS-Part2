@model ServiceRequest
@{
    ViewData["Title"] = "Service Request Details";
}

<h1 class="h3 mb-3">Service Request Details</h1>
<dl class="row">
    <dt class="col-sm-3">Client</dt>
    <dd class="col-sm-9">@Model.Contract?.Client?.Name</dd>
    <dt class="col-sm-3">Contract</dt>
    <dd class="col-sm-9">@Model.Contract?.ServiceLevel</dd>
    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Cost USD</dt>
    <dd class="col-sm-9">@Model.CostUsd.ToString("C")</dd>
    <dt class="col-sm-3">Exchange Rate</dt>
    <dd class="col-sm-9">@Model.ExchangeRateUsdToZar.ToString("N4")</dd>
    <dt class="col-sm-3">Cost ZAR</dt>
    <dd class="col-sm-9">R @Model.CostZar.ToString("N2")</dd>
    <dt class="col-sm-3">Created At</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime()</dd>
</dl>

<a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
<a class="btn btn-outline-secondary" asp-action="Index">Back</a>
