@model Client
@{
    ViewData["Title"] = "Client Details";
}

<h1 class="h3 mb-3">Client Details</h1>
<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Contact Details</dt>
    <dd class="col-sm-9">@Model.ContactDetails</dd>
    <dt class="col-sm-3">Region</dt>
    <dd class="col-sm-9">@Model.Region</dd>
</dl>

<h2 class="h5 mt-4">Contracts</h2>
<div class="table-responsive">
    <table class="table table-sm">
        <thead><tr><th>Service Level</th><th>Status</th><th>Dates</th></tr></thead>
        <tbody>
        @foreach (var contract in Model.Contracts)
        {
            <tr>
                <td>@contract.ServiceLevel</td>
                <td>@contract.Status</td>
                <td>@contract.StartDate.ToShortDateString() - @contract.EndDate.ToShortDateString()</td>
            </tr>
        }
        </tbody>
    </table>
</div>

<a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
<a class="btn btn-outline-secondary" asp-action="Index">Back</a>
